{
  "manifest_version": 3,
  "name": "Overflow Finder",
  "version": "0.1.0",
  "description": "Find which DOM elements are causing horizontal or vertical overflow. Adds an Overflow Finder tab to Chrome DevTools.",
  "minimum_chrome_version": "100",
  "devtools_page": "devtools.html",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["test/fixtures.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
